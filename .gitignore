__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/

# SQLite / runtime data
db/*.db
db/*.sqlite
!db/.gitkeep

# Local test DB generated by regression/smoke runs
aps_test.db*

# SQLite sidecar files (WAL/SHM/journal)
*.db-wal
*.db-shm
*.db-journal
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal
*.maintenance.lock

logs/*.log
logs/*.log.*
!logs/.gitkeep

backups/*.db
!backups/.gitkeep

# IDE
.vscode/
.idea/

# PyInstaller build artifacts
build/
dist/
*.spec

# Optional dependency drop-in folders (keep placeholder if needed)
vendor/**
!vendor/.gitkeep

# Local tools / installer outputs (large binaries)
tools/Chrome.109.0.5414.120.x64/
tools/Chrome.109.0.5414.120.x64_Portable.7z
installer/output/

# E2E evidence (generated by tests/run_complex_excel_cases_e2e.py)
# Keep the human-readable report + summary JSON, ignore heavy per-run artifacts.
evidence/ComplexExcelCases/**
!evidence/ComplexExcelCases/complex_cases_report.md
!evidence/ComplexExcelCases/complex_cases_summary.json

# Local scratch outputs (temporary runs during development)
evidence/ComplexExcelCases_CLI/
evidence/ComplexExcelCases_Extreme*/

# Local editor/agent artifacts
.cursor/
.limcode/

# Runtime scratch
logs/aps_port.txt
logs/aps_host.txt
logs/aps_secret_key.txt

# Full self-test runner logs (keep report file)
evidence/FullSelfTest/logs/

# Large downloaded tools (do not commit)
tools/ungoogled-chromium_*.zip
