__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/

# SQLite / runtime data
db/*.db
db/*.sqlite
!db/.gitkeep

# Local test DB generated by regression/smoke runs
aps_test.db*

# SQLite sidecar files (WAL/SHM/journal)
*.db-wal
*.db-shm
*.db-journal
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal
*.maintenance.lock

logs/*.log
logs/*.log.*
!logs/.gitkeep

backups/*.db
!backups/.gitkeep

# IDE
.vscode/
.idea/

# PyInstaller build artifacts
build/
dist/
*.spec

# Optional dependency drop-in folders (keep placeholder if needed)
vendor/**
!vendor/.gitkeep

# Local tools / installer outputs (large binaries)
tools/Chrome.109.0.5414.120.x64/
tools/Chrome.109.0.5414.120.x64_Portable.7z
installer/output/

# E2E evidence (generated by tests/run_complex_excel_cases_e2e.py)
# Keep the human-readable report + summary JSON, ignore heavy per-run artifacts.
evidence/ComplexExcelCases/**
!evidence/ComplexExcelCases/complex_cases_report.md
!evidence/ComplexExcelCases/complex_cases_summary.json

# Real DB replay evidence (heavy per-run artifacts including DB copies)
evidence/RealDbReplay/

# Local scratch outputs (temporary runs during development)
evidence/ComplexExcelCases_CLI/
evidence/ComplexExcelCases_Extreme*/

# Local editor/agent artifacts
.cursor/
.limcode/

# Runtime scratch
logs/aps_port.txt
logs/aps_host.txt
logs/aps_db_path.txt
logs/aps_runtime.json
logs/aps_secret_key.txt

# Full self-test runner logs (keep report file)
evidence/FullSelfTest/logs/

# Raw test/benchmark console output (binary encoding, only keep formatted reports)
evidence/FullSelfTest/pytest_tests_output.txt
evidence/Benchmark/fjsp_benchmark_console.txt
# Perf profile raw artifacts (keep report only)
evidence/perf_profile_artifacts/

# Large downloaded tools (do not commit)
tools/ungoogled-chromium_*.zip

# Local UI QA artifacts (ad-hoc scripts/reports; keep out of repo by default)
/UI_CHECK_SUMMARY.md
/UI_LAYOUT_CHECK_REPORT.md
/UI_V1_V2_CHECK_MANUAL.md
/UI_V1_V2_CHECK_REPORT.md
/config_ui_verification_report.json
/config_ui_verification_summary.md
/ui_check_helper.html
/analyze_ui_pages.py
/quick_ui_check.py
/final_ui_report.py
/ui_v1_v2_check.py
/check_server.py
/test_ui_mode_switch.py
/verify_config_ui.py
/screenshot_*.png
.playwright-mcp/

# 本地提示词存档（不纳入版本控制）
提示词存档/


# 临时架构债务扫描文件（由审计脚本生成，不纳入版本控制）
backups/_tmp_arch_debt_scan.txt

# LimCode 工作区中间产物（diff/快照/文件清单等）
.limcode_*

# 审计临时 diff 片段（代码审查过程中产出，不纳入版本控制）
audit/**/_tmp_review/
